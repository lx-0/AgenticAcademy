{
  "name": "agentic-academy",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "lint": "pnpm --filter web lint",
    "db:push": "pnpm --filter @agentic-academy/db db:push",
    "db:migrate": "pnpm --filter @agentic-academy/db db:migrate",
    "db:generate": "pnpm --filter @agentic-academy/db db:generate",
    "db:studio": "pnpm --filter @agentic-academy/db db:studio"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "unrs-resolver"
    ]
  }
}
