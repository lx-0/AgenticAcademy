# Database (injected by Railway)
DATABASE_URL="postgresql://user:password@localhost:5432/agentic_academy"

# Redis (injected by Railway)
REDIS_URL="redis://localhost:6379"

# Auth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Anthropic (required for study assistant, triage, personalization)
ANTHROPIC_API_KEY=""

# OpenAI (required for semantic search & recommendations via pgvector)
# Without this, search falls back to keyword matching
OPENAI_API_KEY=""

# Cloudflare R2 (optional at MVP)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# OAuth providers (optional at MVP)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
