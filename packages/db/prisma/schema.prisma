generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// Core user model — used by NextAuth credentials provider
model User {
  id                     String                @id @default(cuid())
  name                   String?
  email                  String                @unique
  password               String?
  role                   UserRole              @default(learner)
  subscriptionTier       SubscriptionTier      @default(free)
  stripeCustomerId       String?               @unique
  stripeSubscriptionId   String?               @unique
  subscriptionEndsAt     DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  enrollments            Enrollment[]
  submissions            CredentialSubmission[]
  reviews                SubmissionReview[]
  learnerProfile         LearnerProfile?
  emailPreference        EmailPreference?
  orgMemberships         OrgMembership[]
  trackAssignments       TrackAssignment[]

  @@map("users")
}

enum UserRole {
  learner
  reviewer
  admin
}

enum SubscriptionTier {
  free
  pro
  enterprise_pilot
  enterprise
}

// Public landing page waitlist
model WaitlistEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("waitlist_emails")
}

model Course {
  id          String       @id @default(cuid())
  title       String
  description String
  slug        String       @unique
  status      CourseStatus @default(draft)
  duration    Int?         // minutes
  imageUrl    String?
  embedding   Unsupported("vector(1536)")?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  modules            Module[]
  enrollments        Enrollment[]
  learningPaths      LearningPath[]
  skillAssessments   SkillAssessment[]
  analyticsSnapshots AnalyticsSnapshot[]

  @@map("courses")
}

enum CourseStatus {
  draft
  published
  archived
}

model Module {
  id          String           @id @default(cuid())
  title       String
  description String?
  order       Int
  duration    Int?             // minutes
  courseId    String
  embedding   Unsupported("vector(1536)")?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  progress         ModuleProgress[]
  assessment       Assessment?
  recommendations  PathRecommendation[]

  @@map("modules")
}

model Lesson {
  id        String     @id @default(cuid())
  title     String
  content   String     // markdown
  order     Int
  type      LessonType @default(text)
  moduleId  String
  embedding Unsupported("vector(1536)")?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  module    Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@map("lessons")
}

enum LessonType {
  text
  lab
  quiz
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(active)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress         ModuleProgress[]
  certificate      Certificate?
  skillAssessments SkillAssessment[]

  @@unique([userId, courseId])
  @@map("enrollments")
}

enum EnrollmentStatus {
  active
  completed
  dropped
}

model ModuleProgress {
  id           String         @id @default(cuid())
  enrollmentId String
  moduleId     String
  status       ProgressStatus @default(not_started)
  score        Int?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  enrollment   Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  module       Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, moduleId])
  @@map("module_progress")
}

enum ProgressStatus {
  not_started
  in_progress
  completed
  failed
}

model Assessment {
  id           String   @id @default(cuid())
  moduleId     String   @unique
  questions    Json     // array of { question, options, correctIndex, explanation }
  passingScore Int      @default(70) // percentage
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  module       Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@map("assessments")
}

model Certificate {
  id             String     @id @default(cuid())
  credentialId   String     @unique @default(uuid())
  enrollmentId   String     @unique
  issuedAt       DateTime   @default(now())
  certificateUrl String?
  recipientEmail String?
  enrollment     Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

// ─── M3: Personalization Engine ──────────────────────────────────────────────

enum ExperienceLevel {
  beginner
  intermediate
  advanced
}

enum LearningPace {
  slow
  moderate
  fast
}

enum MasteryLevel {
  novice
  familiar
  proficient
  expert
}

model LearnerProfile {
  id              String         @id @default(cuid())
  userId          String         @unique
  role            String         // e.g. "software engineer", "data scientist"
  experienceLevel ExperienceLevel @default(beginner)
  learningGoals   String[]       // array of goal strings
  preferredPace   LearningPace   @default(moderate)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  learnerSkills   LearnerSkill[]
  learningPaths   LearningPath[]

  @@map("learner_profiles")
}

model SkillMap {
  id            String         @id @default(cuid())
  name          String         @unique
  description   String
  prerequisites String[]       // array of SkillMap IDs
  moduleId      String?        // optional link to a specific module
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  learnerSkills LearnerSkill[]

  @@map("skill_maps")
}

model LearnerSkill {
  id        String         @id @default(cuid())
  profileId String
  skillId   String
  mastery   MasteryLevel   @default(novice)
  updatedAt DateTime       @updatedAt
  profile   LearnerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill     SkillMap       @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([profileId, skillId])
  @@map("learner_skills")
}

model LearningPath {
  id             String               @id @default(cuid())
  profileId      String
  courseId       String
  moduleSequence String[]             // ordered module IDs — may differ from default order
  rationale      String?              // AI-generated explanation for this path
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  profile        LearnerProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  course         Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  recommendations PathRecommendation[]

  @@unique([profileId, courseId])
  @@map("learning_paths")
}

model PathRecommendation {
  id        String       @id @default(cuid())
  pathId    String
  moduleId  String
  reasoning String       // AI reasoning for recommending this module next
  priority  Int          @default(0)
  dismissed Boolean      @default(false)
  createdAt DateTime     @default(now())
  path      LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  module    Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@map("path_recommendations")
}

// ─── Tier 1 Credential Submission ────────────────────────────────────────────

enum SubmissionStatus {
  pending_triage
  pending_review
  approved
  revision_requested
  rejected
  payment_required
}

enum TriageBucket {
  auto_approve
  standard_review
  flag_rejection
}

enum ReviewDecision {
  approved
  revision_requested
  rejected
}

model CredentialSubmission {
  id                  String                 @id @default(cuid())
  userId              String
  parentId            String?                // null = initial; set on resubmission

  // Narrative sections
  beforeState         String
  whatChanged         String
  outcomeEvidence     String
  governanceStatement String

  // Metadata
  submitterRole       String
  industry            String
  modulesCompleted    String[]               // module IDs validated against enrollment
  implementationDate  DateTime
  hasAttachment       Boolean                @default(false)
  attachmentUrl       String?
  consentToPublish    Boolean                @default(false)
  wordCount           Int

  // Resubmission tracking (attempt 1 = initial, 2 = free, 3+ = $15 fee)
  attempt             Int                    @default(1)
  paymentIntentId     String?                // stub for $15 fee gate

  status              SubmissionStatus       @default(pending_triage)

  user                User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent              CredentialSubmission?  @relation("Resubmissions", fields: [parentId], references: [id])
  resubmissions       CredentialSubmission[] @relation("Resubmissions")
  triageResult        TriageResult?
  review              SubmissionReview?

  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@map("credential_submissions")
}

model TriageResult {
  id              String               @id @default(cuid())
  submissionId    String               @unique

  // Per-criterion scores 0–3
  scoreWorkflow   Int
  scoreOutcome    Int
  scoreGovernance Int
  scoreRole       Int
  totalScore      Int

  bucket          TriageBucket
  flagReason      String?
  humanAgreed     Boolean?             // null = not yet spot-checked

  submission      CredentialSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  createdAt       DateTime             @default(now())

  @@map("triage_results")
}

model SubmissionReview {
  id              String               @id @default(cuid())
  submissionId    String               @unique
  reviewerId      String

  // Reviewer scores (may override triage)
  scoreWorkflow   Int
  scoreOutcome    Int
  scoreGovernance Int
  scoreRole       Int
  totalScore      Int

  decision        ReviewDecision
  feedbackMessage String?
  isSpotCheck     Boolean              @default(false)

  submission      CredentialSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer        User                 @relation(fields: [reviewerId], references: [id])
  createdAt       DateTime             @default(now())

  @@map("submission_reviews")
}

// ─── M3: Skill Assessments + ROI Analytics ───────────────────────────────────

enum AssessmentPhase {
  pre
  post
}

model SkillAssessment {
  id           String          @id @default(cuid())
  enrollmentId String
  courseId     String
  phase        AssessmentPhase
  // array of { skillName, question, options[], correctIndex, explanation }
  questions    Json            @default("[]")
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  enrollment   Enrollment      @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  course       Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  scores       SkillScore[]

  @@unique([enrollmentId, phase])
  @@map("skill_assessments")
}

model SkillScore {
  id                String          @id @default(cuid())
  skillAssessmentId String
  skillName         String
  score             Int             // 0–100
  createdAt         DateTime        @default(now())
  skillAssessment   SkillAssessment @relation(fields: [skillAssessmentId], references: [id], onDelete: Cascade)

  @@map("skill_scores")
}

model AnalyticsSnapshot {
  id                  String   @id @default(cuid())
  courseId            String
  snapshotAt          DateTime @default(now())
  totalEnrollments    Int      @default(0)
  completedCount      Int      @default(0)
  completionRate      Float    @default(0)
  avgPreScore         Float?
  avgPostScore        Float?
  avgImprovementPct   Float?
  avgTimeToCompletion Float?   // days
  createdAt           DateTime @default(now())
  course              Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("analytics_snapshots")
}

// ─── M4: Team & Organization Management ──────────────────────────────────────

enum OrgRole {
  org_admin
  manager
  learner
}

enum BulkEnrollStatus {
  pending
  processing
  completed
  failed
}

model Organization {
  id          String         @id @default(cuid())
  name        String
  domain      String?        @unique // e.g. "company.com" for domain-based auto-join
  settings    Json           @default("{}")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  memberships     OrgMembership[]
  invites         OrgInvite[]
  tracks          LearningTrack[]
  bulkEnrollments BulkEnrollment[]

  @@map("organizations")
}

model OrgMembership {
  id       String       @id @default(cuid())
  orgId    String
  userId   String
  role     OrgRole      @default(learner)
  joinedAt DateTime     @default(now())
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_memberships")
}

model OrgInvite {
  id        String       @id @default(cuid())
  orgId     String
  token     String       @unique @default(cuid())
  email     String?      // null = generic link; set = email-specific invite
  role      OrgRole      @default(learner)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_invites")
}

model LearningTrack {
  id          String          @id @default(cuid())
  orgId       String
  name        String
  description String?
  courseIds   String[]        // ordered list of course IDs
  roleTarget  String?         // e.g. "software engineer" — for role-based assignment
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  org         Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignments TrackAssignment[]

  @@map("learning_tracks")
}

model TrackAssignment {
  id         String        @id @default(cuid())
  trackId    String
  userId     String
  assignedAt DateTime      @default(now())
  track      LearningTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([trackId, userId])
  @@map("track_assignments")
}

model BulkEnrollment {
  id           String           @id @default(cuid())
  orgId        String
  courseId     String
  requestedBy  String           // userId of org_admin who triggered it
  totalCount   Int
  successCount Int              @default(0)
  failedCount  Int              @default(0)
  status       BulkEnrollStatus @default(pending)
  results      Json             @default("[]") // [{ userId, email, status, enrollmentId? }]
  createdAt    DateTime         @default(now())
  completedAt  DateTime?
  org          Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("bulk_enrollments")
}

// ─── M4: Email Notifications ──────────────────────────────────────────────────

enum EmailType {
  welcome
  enrollment_confirmation
  progress_nudge
  module_completion
  course_completion
  assessment_results
  admin_digest
}

model EmailPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  nudges    Boolean  @default(true)   // opt out of progress_nudge and module_completion
  digest    Boolean  @default(true)   // opt out of admin_digest
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_preferences")
}

model EmailLog {
  id        String    @id @default(cuid())
  userId    String?
  email     String
  type      EmailType
  subject   String
  status    String    @default("sent") // sent | failed
  error     String?
  createdAt DateTime  @default(now())

  @@map("email_logs")
}
